# All settings are optional; defaults shown.

# Where fetched GIBS tiles are cached on disk
CACHE_DIR=/data/tile-cache
# Cache size cap in bytes (1 GiB). Oldest tiles are evicted past this.
CACHE_MAX_BYTES=1073741824

# Hard cap on GIBS tile fetches per request (zoom degrades to fit)
MAX_TILES_PER_REQUEST=64
# Max concurrent outbound requests to GIBS (be a polite client)
GIBS_MAX_CONCURRENCY=8
REQUEST_TIMEOUT_SECONDS=10
FETCH_RETRIES=2

# Max bbox span in degrees per axis; set to 0 to disable the limit
MAX_BBOX_DEG=60
# rows * cols cap for grid requests
MAX_GRID_CELLS=65536

# How often to re-read GIBS GetCapabilities for latest-date info (seconds)
CAPABILITIES_REFRESH_SECONDS=21600
